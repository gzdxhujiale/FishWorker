{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "人类使用手册",
  "version": "0.1.0",
  "identifier": "com.administrator.humanmanual",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "人类使用手册",
        "width": 1100,
        "height": 660,
        "minWidth": 680,
        "minHeight": 460,
        "decorations": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}